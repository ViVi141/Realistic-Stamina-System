{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RSS Params Extension (v5 + v6)",
  "description": "Additive fields for SCR_RSS_Params. v5 dual-pool + v6 CP-W' fields.",
  "type": "object",
  "properties": {
    "sustainable_watts": { "type": "number", "minimum": 100, "default": 780.0 },
    "v5_walk_speed_ms": { "type": "number", "minimum": 0.5, "default": 1.4 },
    "v5_run_speed_ms": { "type": "number", "minimum": 1.0, "default": 2.8 },
    "v5_sprint_speed_ms": { "type": "number", "minimum": 2.0, "default": 4.5 },
    "anaerobic_sprint_enable_threshold": { "type": "number", "minimum": 0, "maximum": 1, "default": 0.2 },
    "burst_cooldown_full_seconds": { "type": "number", "minimum": 30, "default": 180.0 },
    "burst_cooldown_short_seconds": { "type": "number", "minimum": 10, "default": 75.0 },
    "anaerobic_drain_per_sec": {
      "type": "number",
      "minimum": 0.01,
      "default": 0.12,
      "description": "Deprecated v6: ignored at runtime; W' uses power integral"
    },
    "anaerobic_recovery_per_sec": { "type": "number", "minimum": 0.01, "default": 0.08 },
    "critical_power_watts": { "type": "number", "minimum": 500, "default": 780.0 },
    "w_prime_max_joules": { "type": "number", "minimum": 5000, "default": 20000.0 },
    "w_prime_recovery_w_per_s": { "type": "number", "minimum": 1, "default": 12.0 },
    "sprint_power_cap_watts": { "type": "number", "minimum": 500, "default": 2200.0 }
  },
  "additionalProperties": true
}
