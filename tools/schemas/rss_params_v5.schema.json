{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RSS v5 Params Extension",
  "description": "Additive fields for SCR_RSS_Params (v5 dual-pool). Legacy v3/v4 fields remain in rss_pipeline_v4.",
  "type": "object",
  "properties": {
    "sustainable_watts": { "type": "number", "minimum": 100, "default": 400.0 },
    "v5_walk_speed_ms": { "type": "number", "minimum": 0.5, "default": 1.4 },
    "v5_run_speed_ms": { "type": "number", "minimum": 1.0, "default": 2.8 },
    "v5_sprint_speed_ms": { "type": "number", "minimum": 2.0, "default": 4.0 },
    "anaerobic_sprint_enable_threshold": { "type": "number", "minimum": 0, "maximum": 1, "default": 0.2 },
    "burst_cooldown_full_seconds": { "type": "number", "minimum": 30, "default": 180.0 },
    "burst_cooldown_short_seconds": { "type": "number", "minimum": 10, "default": 75.0 },
    "anaerobic_drain_per_sec": { "type": "number", "minimum": 0.01, "default": 0.12 },
    "anaerobic_recovery_per_sec": { "type": "number", "minimum": 0.01, "default": 0.08 }
  },
  "additionalProperties": true
}
